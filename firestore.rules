rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Any Firebase Auth session (including anonymous) can read/write their own email path.
    // Anonymous auth is used so no Google popup is needed for Firestore access.
    match /users/{email}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
